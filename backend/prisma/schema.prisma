generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(uuid())
  username     String  @unique
  email        String  @unique
  fullName     String
  password     String
  avatar       String
  coverImage   String?
  refreshToken String?

  videos       Video[] @relation("Owner")
  watchHistory Video[] @relation("WatchHistory")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Video {
  id          String  @id @default(uuid())
  videoFile   String
  thumbnail   String
  title       String
  description String
  duration    Int
  views       Int     @default(0)
  isPublished Boolean @default(true)

  ownerId String
  owner   User   @relation("Owner", fields: [ownerId], references: [id])

  watchedBy User[] @relation("WatchHistory")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
